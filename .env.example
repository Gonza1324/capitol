# Supabase project URL, for example: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key. Safe for browser usage; RLS protects data access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. Server-side only; required for admin user creation/editing in Settings.
SUPABASE_SERVICE_ROLE_KEY=

# Google Calendar OAuth. Server-side only except the public feature flag.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
NEXT_PUBLIC_GOOGLE_CALENDAR_ENABLED=false
